apiVersion: apps/v1
kind: Deployment
metadata:
  name: apache-deployment
  namespace: default
spec:
  replicas: 1
  selector:
    matchLabels:
      app: apache
  template:
    metadata:
      labels:
        app: apache
    spec:
      containers:
        - name: apache
          image: {{ acr_name }}/{{ apache_image_name }}:{{ apache_image_tag }}
          ports:
            - containerPort: 80
          volumeMounts:
            - name: apache-storage
              mountPath: /usr/local/apache2/htdocs
      volumes:
        - name: apache-storage
          persistentVolumeClaim:
            claimName: apache-pvc
      imagePullSecrets:
        - name: acr-secret