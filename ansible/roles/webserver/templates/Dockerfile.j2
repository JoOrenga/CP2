FROM nginx:alpine

# Instalar openssl y apache2-utils para htpasswd
RUN apk add --no-cache openssl apache2-utils

# Crear certificado autofirmado
RUN openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -keyout /etc/nginx/ssl/nginx.key \
    -out /etc/nginx/ssl/nginx.crt \
    -subj "/C={{ cert_country }}/O={{ cert_org }}/CN={{ cert_domain }}"

# Crear credenciales htpasswd
RUN htpasswd -bc /etc/nginx/.htpasswd {{ http_user }} {{ http_password }}

# Copiar configuración y contenido
COPY nginx.conf /etc/nginx/nginx.conf
COPY index.html /usr/share/nginx/html/index.html

EXPOSE 443
CMD ["nginx", "-g", "daemon off;"]