events {}

http {
    server {
        listen 443 ssl;
        server_name {{ cert_domain }};

        ssl_certificate     /etc/nginx/ssl/nginx.crt;
        ssl_certificate_key /etc/nginx/ssl/nginx.key;

        location / {
            auth_basic           "Acceso Restringido";
            auth_basic_user_file /etc/nginx/.htpasswd;
            root   /usr/share/nginx/html;
            index  index.html;
        }
    }
}